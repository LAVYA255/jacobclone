---
---
<section class="relative w-full overflow-hidden bg-black hero-section">
  <video
    class="absolute inset-0 w-full h-full object-cover hero-media"
    src="/js-assets/hero-video.mp4"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="/js-assets/JakobSimon0042.webp"
  ></video>
  <noscript>
    <img src="/js-assets/JakobSimon0042.webp" alt="Jakob Simon Zürich" class="absolute inset-0 w-full h-full object-cover hero-media" />
  </noscript>
</section>

<style>
  .hero-section {
    height: calc(100vh - 124px);
    min-height: 640px;
  }
  .hero-media {
    object-position: center 28%;
  }
  @media (max-width: 1024px) {
    .hero-section {
      height: calc(100vh - 78px);
      min-height: 560px;
    }
  }
  @media (max-width: 640px) {
    .hero-section {
      height: calc(100svh - 78px);
      min-height: 480px;
    }
  }
</style>
