---
---
<section class="relative w-full overflow-hidden bg-black hero-section">
  <video
    class="absolute inset-0 w-full h-full object-cover"
    src="/js-assets/hero-video.mp4"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="/js-assets/JakobSimon0042.webp"
  ></video>
  <noscript>
    <img src="/js-assets/JakobSimon0042.webp" alt="Jakob Simon Zürich" class="absolute inset-0 w-full h-full object-cover" />
  </noscript>
</section>

<style>
  .hero-section {
    aspect-ratio: 16 / 5;
    width: 100%;
    max-height: calc(100vh - 230px);
  }
  @media (max-width: 1024px) {
    .hero-section {
      aspect-ratio: 4 / 5;
      max-height: calc(100svh - 160px);
      min-height: 480px;
    }
  }
  @media (max-width: 640px) {
    .hero-section {
      aspect-ratio: 3 / 4;
      max-height: calc(100svh - 130px);
      min-height: 460px;
    }
  }
</style>
