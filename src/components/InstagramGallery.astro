---
const tiles = [
  { image: '/js-assets/JakobSimon0014.jpg', alt: 'Editorial portrait — wide brim hat' },
  { image: '/js-assets/JakobSimon0006.jpg', alt: 'Editorial portrait — silk scarves' },
  { image: '/js-assets/IMG_2737_3.jpg', alt: 'Behind the scenes — atelier' },
  { image: '/js-assets/JakobSimon0394.webp', alt: 'Editorial portrait — autumn scarf' },
  { image: '/js-assets/IG_Beitrage_JS-2.png', alt: 'Atelier campaign poster' },
];
---
<section class="pb-24 md:pb-32 bg-white">
  <div class="grid grid-cols-2 md:grid-cols-5 gap-1 fade-up">
    {tiles.map((t) => (
      <a href="https://instagram.com" class="relative block group overflow-hidden bg-black aspect-square">
        <img
          src={t.image}
          alt={t.alt}
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/25 transition-colors flex items-center justify-center">
          <svg class="w-7 h-7 text-white opacity-0 group-hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
        </div>
      </a>
    ))}
  </div>
</section>
