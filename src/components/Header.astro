---
const left = [
  { label: 'Products', href: '/collections/all' },
  { label: 'About Us', href: '/pages/about-us' },
];
const right = [
  { label: 'JSWorld', href: '/pages/jsworld' },
  { label: 'Contact', href: '/pages/contact' },
];
const all = [...left, ...right];
---
<header class="sticky top-0 z-40 bg-white/95 backdrop-blur-sm border-b border-border-soft">
  <div class="container-js relative flex items-center h-[78px] md:h-[96px]">
    <button id="menu-toggle" class="lg:hidden p-2 -ml-2" aria-label="Open menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>

    <div class="hidden lg:flex items-center gap-9 flex-1">
      <button class="nav-link" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </button>
      {left.map((l) => (
        <a href={l.href} class="nav-link">{l.label}</a>
      ))}
    </div>

    <a href="/" class="absolute left-1/2 -translate-x-1/2 flex items-center" aria-label="Jakob Simon Zürich">
      <img
        src="/js-assets/jslogo.png"
        alt="Jakob Simon Zürich"
        class="h-10 md:h-[68px] w-auto select-none"
        draggable="false"
      />
    </a>

    <div class="hidden lg:flex items-center gap-9 flex-1 justify-end">
      {right.map((l) => (
        <a href={l.href} class="nav-link">{l.label}</a>
      ))}
      <a href="/account/login" class="nav-link" aria-label="Account">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>
      </a>
      <button class="nav-link relative" aria-label="Cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 7h12l-1.2 11.2A2 2 0 0 1 14.8 20H9.2a2 2 0 0 1-2-1.8L6 7z"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/></svg>
      </button>
    </div>

    <div class="flex lg:hidden items-center gap-4 ml-auto">
      <button class="nav-link" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </button>
      <button class="nav-link" aria-label="Cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 7h12l-1.2 11.2A2 2 0 0 1 14.8 20H9.2a2 2 0 0 1-2-1.8L6 7z"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden border-t border-border-soft">
    <nav class="flex flex-col py-2">
      {all.map((l) => (
        <a href={l.href} class="px-6 py-3 nav-link border-b border-border-soft">{l.label}</a>
      ))}
      <a href="/account/login" class="px-6 py-3 nav-link">Log in</a>
    </nav>
  </div>
</header>

<style>
  .js-wordmark {
    font-family: 'Cormorant', 'Cormorant Garamond', Georgia, serif;
    font-weight: 700;
    font-size: clamp(17px, 2.4vw, 30px);
    letter-spacing: 0.02em;
    color: #1c1d1d;
    white-space: nowrap;
  }
  .js-zurich {
    font-family: 'Cormorant', 'Cormorant Garamond', Georgia, serif;
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.42em;
    margin-top: 3px;
    color: #1c1d1d;
  }
  @media (min-width: 768px) {
    .js-zurich { font-size: 11px; margin-top: 4px; }
  }
</style>

<script>
  const t = document.getElementById('menu-toggle');
  const m = document.getElementById('mobile-menu');
  t?.addEventListener('click', () => m?.classList.toggle('hidden'));
</script>
